\begin_layout Standard
\begin_inset listings
inline false
status open

\begin_layout Plain Layout

CREATE TABLE IF NOT EXISTS sensor_data (
\end_layout

\begin_layout Plain Layout

	id INTEGER PRIMARY KEY AUTOINCREMENT,
\end_layout

\begin_layout Plain Layout

	timestamp TEXT,
\end_layout

\begin_layout Plain Layout

	temperature REAL,
\end_layout

\begin_layout Plain Layout

	humidity REAL,
\end_layout

\begin_layout Plain Layout

	action TEXT)
\end_layout

\end_inset


\end_layout

\begin_layout Standard
temperature, humidity and action can be NULL since when there is an action
 there is no data and vice versa.
\end_layout

\begin_layout Standard
timestamp could have the 
\begin_inset Quotes eld
\end_inset

NOT NULL
\begin_inset Quotes erd
\end_inset

