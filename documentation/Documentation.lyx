\end_layout

\begin_layout Plain Layout

setInterval(updateStatus, 2000);
\end_layout

\end_inset


\end_layout

\begin_layout Standard
updateData is a function in index.html that calls the /api/data route and
 update the display accordingly to the data sent by the server.
\end_layout

